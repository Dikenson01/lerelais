{
  "name": "lerelais-platform",
  "private": true,
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx turbo dev",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "NODE_OPTIONS=\"--max-old-space-size=400\" npx turbo build --concurrency=1",
    "start": "cd apps/api && npm start",
    "start:api": "cd apps/api && npm start",
    "start:web": "cd apps/web && npm start",
    "db:push": "cd packages/db && npx drizzle-kit push",
    "db:generate": "cd packages/db && npx drizzle-kit generate",
    "db:studio": "cd packages/db && npx drizzle-kit studio"
  },
  "dependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
